{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "react", "react-dom"],
    "paths": {
      "@present-it/engine": ["./packages/engine/src/index.ts"],
      "@present-it/engine/*": ["./packages/engine/src/*"],
      "@present-it/components": ["./packages/components/src/index.ts"],
      "@present-it/theme": ["./packages/theme/src/index.ts"],
      "@present-it/theme/*": ["./packages/theme/src/*"],
      "@present-it/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@present-it/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@present-it/plugin-ui": ["./packages/plugin-ui/src/index.ts"],
      "@present-it/plugin-poll": ["./packages/plugin-poll/src/index.ts"],
      "@present-it/plugin-poll/*": ["./packages/plugin-poll/src/*"],
      "@present-it/live-server": ["./packages/live-server/src/index.ts"],
      "@present-it/thumbnails": ["./packages/thumbnails/src/index.ts"],
      "@present-it/thumbnails/*": ["./packages/thumbnails/src/*"],
      "present-relay": ["./packages/present-relay/src/index.ts"]
    }
  },
  "include": ["packages", "presentations", "types"],
  "exclude": ["**/node_modules", "**/dist", "poc"]
}
