{
  "name": "@liebstoeckel/cli",
  "version": "0.3.6",
  "description": "The liebstoeckel CLI to scaffold, develop, build, and present code-first decks.",
  "keywords": [
    "liebstoeckel",
    "slides",
    "presentation-slides",
    "ai-agents",
    "ai",
    "skills",
    "cli",
    "mdx",
    "react"
  ],
  "homepage": "https://liebstoeckel.app",
  "bugs": "https://github.com/liebstoeckel/liebstoeckel-app/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liebstoeckel/liebstoeckel-app.git",
    "directory": "packages/cli"
  },
  "license": "MPL-2.0",
  "author": "Leon Kaucher <contact@liebstoeckel.app>",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "skill",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "type": "module",
  "bin": {
    "liebstoeckel": "./src/cli.ts",
    "lst": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/cli.ts",
    "./new": "./src/new.ts"
  },
  "dependencies": {
    "@liebstoeckel/engine": "workspace:*",
    "@liebstoeckel/live-server": "workspace:*",
    "@liebstoeckel/present-relay": "workspace:*",
    "@liebstoeckel/registry": "workspace:*",
    "@liebstoeckel/theme": "workspace:*",
    "@liebstoeckel/thumbnails": "workspace:*",
    "citty": "^0.2.2"
  },
  "peerDependencies": {
    "react": ">=19.2.7",
    "react-dom": ">=19.2.7"
  }
}
