---
// Standalone privacy utility: clears the buncus comment consent + sign-in from
// THIS origin's localStorage. Linked from the Datenschutzerklärung so withdrawing
// consent is one click (Art. 7(3) DSGVO: as easy to withdraw as to give), which
// keeps the comment widget itself uncluttered. localStorage is per-origin, so this
// page must be served from the same docs origin the loader stored the keys on —
// it is (docs.liebstoeckel.app in prod, the int docs host on int). No docs chrome:
// its own document with inline styles, mirroring 404.astro.
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Einwilligung widerrufen — liebstoeckel</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/schibsted-grotesk.woff2" as="font" type="font/woff2" crossorigin />
    <style is:inline>
      @font-face {
        font-family: "Schibsted Grotesk Variable";
        src: url("/fonts/schibsted-grotesk.woff2") format("woff2");
        font-weight: 400 700;
        font-display: swap;
      }
      :root {
        --bg: #10140e;
        --heading: #f4f1e6;
        --text: #e9e6d7;
        --text-2: #9da28c;
        --gold: #c9a24b;
        --gold-soft: #e0c580;
        --gold-hover: #d9b461;
        --line: #2c3326;
        --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        --sans: "Schibsted Grotesk Variable", system-ui, sans-serif;
        --mono: ui-monospace, "SF Mono", "JetBrains Mono Variable", monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        min-height: 100dvh;
        background: var(--bg);
        background-image:
          radial-gradient(1200px 760px at 100% -8%, rgba(201, 162, 75, 0.07), transparent 58%),
          radial-gradient(900px 720px at 0% 112%, rgba(44, 64, 48, 0.30), transparent 60%);
        background-attachment: fixed;
        color: var(--text);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        display: flex;
        flex-direction: column;
      }
      a { color: inherit; }
      :focus-visible { outline: 2px solid var(--gold-soft); outline-offset: 3px; border-radius: 3px; }
      .lockup {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 6vw, 4rem);
        font-weight: 700;
        font-size: 1.0625rem;
        letter-spacing: -0.035em;
        text-decoration: none;
      }
      .lockup svg { width: 26px; height: 26px; display: block; }
      .lockup span {
        background: linear-gradient(118deg, var(--heading) 26%, var(--gold-soft));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      main {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 clamp(1.5rem, 6vw, 4rem) clamp(4rem, 12vh, 9rem);
        max-width: 760px;
        width: 100%;
        margin: 0 auto;
      }
      .eyebrow {
        font-family: var(--mono);
        font-size: 0.8125rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: clamp(1rem, 3vh, 1.5rem);
      }
      h1 {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.02;
        font-size: clamp(2.25rem, 6vw, 3.5rem);
        color: var(--heading);
        text-wrap: balance;
      }
      .status {
        margin: clamp(1.25rem, 3vh, 1.75rem) 0 0;
        font-size: clamp(1.0625rem, 1.6vw, 1.2rem);
        line-height: 1.55;
        color: var(--text);
        max-width: 56ch;
      }
      .status code {
        font-family: var(--mono);
        font-size: 0.9em;
        color: var(--gold-soft);
      }
      .lede2 {
        margin: 0.9rem 0 0;
        color: var(--text-2);
        font-size: 1rem;
        line-height: 1.55;
        max-width: 60ch;
      }
      .actions { margin-top: clamp(2rem, 5vh, 3rem); display: flex; gap: 1.5rem; flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; height: 48px; padding: 0 1.4rem;
        border-radius: 8px; font-family: inherit; font-weight: 600; font-size: 1rem;
        letter-spacing: -0.01em; text-decoration: none;
        transition: background 160ms var(--ease-out), transform 160ms var(--ease-out);
      }
      .btn--primary { background: var(--gold); color: var(--bg); }
      .btn--primary:hover { background: var(--gold-hover); transform: translateY(-1px); }
      .note { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line); color: var(--text-2); font-size: 0.9rem; line-height: 1.6; }
    </style>
  </head>
  <body>
    <header>
      <a class="lockup" href="/" aria-label="liebstoeckel docs — home">
        <svg viewBox="0 0 64 64" fill="none" aria-hidden="true"><g transform="translate(32 32) scale(1.25) translate(-31.05 -35.6)"><rect x="15" y="17.5" width="20" height="11.25" rx="3" fill="#c9a24b"/><rect x="31.5" y="29.5" width="16" height="9" rx="2.5" fill="#c9a24b"/><rect x="22" y="39.5" width="12" height="6.75" rx="2" fill="#c9a24b"/><path d="M28 28.75 Q31.4 29.2 31.5 33 L38.5 29.5 Q34.9 29.1 35 26 Z" fill="#c9a24b"/><path d="M38 38.5 Q34.3 39 34 43 L28 39.5 Q31.4 39.2 31.5 36 Z" fill="#c9a24b"/><path d="M28.5 45.5 Q31.1 46.6 31.2 48.5 L31.2 52.2 Q31.2 53.7 32.6 53.7 Q34 53.7 34 52.2 L34 45 Z" fill="#c9a24b"/></g></svg>
        <span>liebstoeckel</span>
      </a>
    </header>
    <main>
      <p class="eyebrow">Datenschutz / Privacy</p>
      <h1>Einwilligung widerrufen</h1>
      <p class="status" id="status">Wird verarbeitet …</p>
      <p class="lede2">
        Damit ziehen Sie Ihre Einwilligung in die Kommentarfunktion zurück. Kommentare werden erst
        wieder geladen, wenn Sie erneut einwilligen. Bereits an GitHub übermittelte Daten oder
        veröffentlichte Kommentare werden hierdurch nicht entfernt.
        <br /><br />
        <em>This revokes your consent for the comment feature on this site. Comments won't load again
        until you opt in. Data already sent to GitHub, or comments you posted, are not removed.</em>
      </p>
      <noscript>
        <p class="lede2">
          JavaScript ist deaktiviert. Bitte löschen Sie die Website-Daten dieser Domain in Ihren
          Browser-Einstellungen (insbesondere die localStorage-Einträge <code>buncus-consent</code>
          und <code>buncus-session</code>).
        </p>
      </noscript>
      <div class="actions">
        <a class="btn btn--primary" href="/">Zurück zur Dokumentation</a>
      </div>
      <p class="note">
        Hinweis: Diese Seite wirkt nur für die Domain, von der sie geladen wird, da die Einwilligung
        im lokalen Speicher (localStorage) Ihres Browsers für genau diese Domain abgelegt ist.
      </p>
    </main>
    <script>
      const KEYS = ["buncus-consent", "buncus-session"];
      const el = document.getElementById("status");
      try {
        const removed = KEYS.filter((k) => {
          const had = localStorage.getItem(k) !== null;
          if (had) localStorage.removeItem(k);
          return had;
        });
        el.innerHTML =
          removed.length > 0
            ? `Erledigt. Gelöscht: ${removed.map((k) => `<code>${k}</code>`).join(", ")}. Done; consent withdrawn.`
            : "Es waren keine Einträge gespeichert, es ist nichts zu widerrufen. Nothing was stored; nothing to revoke.";
      } catch {
        el.textContent =
          "Der lokale Speicher ist nicht zugänglich. Bitte löschen Sie die Website-Daten dieser Domain in den Browser-Einstellungen. Local storage is unavailable; clear this site's data in your browser settings.";
      }
    </script>
  </body>
</html>
