{
  "name": "@liebstoeckel/engine",
  "version": "0.3.5",
  "description": "The compiler, React runtime, and single-file build pipeline at the core of liebstoeckel.",
  "keywords": [
    "liebstoeckel",
    "slides",
    "presentation-slides",
    "ai-agents",
    "ai",
    "skills",
    "mdx",
    "react",
    "motion",
    "tailwindcss",
    "bun"
  ],
  "homepage": "https://liebstoeckel.app",
  "bugs": "https://github.com/liebstoeckel/liebstoeckel-app/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liebstoeckel/liebstoeckel-app.git",
    "directory": "packages/engine"
  },
  "license": "MPL-2.0",
  "author": "Leon Kaucher <contact@liebstoeckel.app>",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./live": "./src/live/index.ts",
    "./build": "./src/build/buildDeck.ts",
    "./build/source-package": "./src/build/source-package.ts",
    "./build/licenses": "./src/build/licenses.ts",
    "./build/thumbnails": "./src/build/thumbnails.ts",
    "./build/capture-protocol": "./src/build/capture-protocol.ts",
    "./mdx-plugin": "./src/build/mdx-plugin.ts",
    "./visx-esm-plugin": "./src/build/visx-esm-plugin.ts",
    "./code": "./src/code/macro.ts"
  },
  "dependencies": {
    "@liebstoeckel/components": "workspace:^",
    "@liebstoeckel/plugin-sdk": "workspace:^",
    "@liebstoeckel/plugin-ui": "workspace:^",
    "@liebstoeckel/theme": "workspace:^",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@shikijs/rehype": "^3.23.0",
    "bun-plugin-tailwind": "^0.1.2",
    "motion": "^12.40.0",
    "qrcode": "^1.5.4",
    "shiki": "^3.23.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yjs": "^13.6.31"
  }
}
