# dependencies
node_modules/

# build output (single-file decks are generated)
dist/
# TanStack Start / Nitro build output — rebuilt in-image by the Dockerfile
.output/
.nitro/
.tanstack/

# astro docs cache
.astro/

# logs / scratch
*.log
_shot.png
_ft/

# test temp dirs created IN the source tree (need repo node_modules for bundling);
# leak only if a test is killed/timed-out before its cleanup runs — never commit them
.vt-*/
.verify-*/
srvplugin-*/

# kustomize --enable-helm chart cache (pulled next to the kustomization on local builds)
deploy/**/charts/

# editor / OS
.DS_Store
.idea/
*.swp
.npmrc

# stray verification screenshots (root, hidden)
/.*.png
