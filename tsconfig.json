{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "react", "react-dom"],
    "paths": {
      "@present-it/engine": ["./packages/engine/src/index.ts"],
      "@present-it/engine/*": ["./packages/engine/src/*"],
      "@present-it/components": ["./packages/components/src/index.ts"],
      "@present-it/theme": ["./packages/theme/src/index.ts"]
    }
  }
}
