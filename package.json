{
  "name": "liebstoeckel",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "presentations/*"
  ],
  "scripts": {
    "gen": "bun run packages/theme/src/gen.ts",
    "demo:dev": "cd presentations/demo && bun --hot ./server.ts",
    "demo:build": "cd presentations/demo && bun run build.ts",
    "showcase:dev": "cd presentations/visx-showcase && bun --hot ./server.ts",
    "showcase:build": "cd presentations/visx-showcase && bun run build.ts",
    "registry:dev": "cd presentations/registry-demo && bun --hot ./server.ts",
    "registry:build": "cd presentations/registry-demo && bun run build.ts",
    "add": "bun packages/cli/src/cli.ts add",
    "poll:build": "cd presentations/poll-demo && bun run build.ts",
    "poll:live": "bun run poll:build && bun packages/live-server/src/cli.ts presentations/poll-demo/dist/index.html",
    "live": "bun packages/live-server/src/cli.ts",
    "relay": "bun packages/present-relay/src/cli.ts",
    "thumbs": "bun packages/thumbnails/src/cli.ts",
    "export": "bun packages/cli/src/cli.ts export",
    "test": "bun test packages",
    "test:e2e:os": "LIEBSTOECKEL_E2E_OS_SMOKE=1 bun test packages/e2e/src/cli-os-smoke.test.ts",
    "docs:dev": "cd packages/docs && bun --bun astro dev --host",
    "docs:build": "cd packages/docs && bun --bun astro build",
    "landing:dev": "cd packages/landing && bun --bun astro dev --host",
    "landing:build": "cd packages/landing && bun --bun astro build",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@types/bun": "^1.3.14",
    "nitro": "npm:nitro-nightly@3.0.1-20260605-145636-4ab22a9d",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "bun-plugin-tailwind": "0.1.2",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@visx/axis": "^3.12.0",
    "@visx/curve": "^3.12.0",
    "@visx/glyph": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/grid": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/heatmap": "^3.12.0",
    "@visx/hierarchy": "^3.12.0",
    "@visx/legend": "^3.12.0",
    "@visx/mock-data": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/text": "^3.12.0",
    "motion": "12.40.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yjs": "^13.6.31"
  },
  "license": "MPL-2.0"
}
